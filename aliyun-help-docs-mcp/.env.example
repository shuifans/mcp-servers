# IQS API Key (required for live calls; leave empty for mock testing)
IQS_API_KEY=your_iqs_api_key_here

# IQS Base URL
IQS_BASE_URL=https://cloud-iqs.aliyuncs.com

# Local SQLite cache for fetched docs
DOC_CACHE_PATH=./data/cache/doc_cache.sqlite

# Cache TTL in hours (default: 24)
DOC_CACHE_TTL_HOURS=24

# URL whitelist (comma-separated). For alibabacloud.com only paths starting with /help are allowed.
URL_WHITELIST=help.aliyun.com,www.alibabacloud.com/help

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
